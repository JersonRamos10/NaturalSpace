{
  "info": {
    "_postman_id": "naturalspace-api-collection",
    "name": "NaturalSpace API",
    "description": "Coleccion para testear la API de NaturalSpace (mini Slack/Discord).\n\n**Variables de entorno recomendadas:**\n- `baseUrl`: `http://localhost:5000` (o el puerto donde corre la API)\n- `token`: Se actualiza automaticamente tras hacer login.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Juan Perez\",\n  \"userName\": \"juanp\",\n  \"email\": \"juan@example.com\",\n  \"password\": \"Password123!\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "pm.environment.set('token', jsonData.token);",
                  "pm.environment.set('refreshToken', jsonData.refreshToken);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"juan@example.com\",\n  \"userName\": \"juanp\",\n  \"password\": \"Password123!\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "pm.environment.set('token', jsonData.token);",
                  "pm.environment.set('refreshToken', jsonData.refreshToken);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/refresh",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/logout",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        }
      ]
    },
    {
      "name": "Workspaces",
      "item": [
        {
          "name": "Create Workspace",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/api/workspaces",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Mi Equipo Dev\",\n  \"description\": \"Workspace para el equipo de desarrollo\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "List My Workspaces",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/api/workspaces"
          }
        },
        {
          "name": "Get Workspace by Id",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/api/workspaces/{{workspaceId}}"
          }
        },
        {
          "name": "Update Workspace",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/api/workspaces/{{workspaceId}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Mi Equipo Dev Actualizado\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Delete Workspace",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/api/workspaces/{{workspaceId}}"
          }
        }
      ]
    },
    {
      "name": "Members",
      "item": [
        {
          "name": "List Members",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/api/workspaces/{{workspaceId}}/members"
          }
        },
        {
          "name": "Add Member",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/api/workspaces/{{workspaceId}}/members/{{userId}}"
          }
        },
        {
          "name": "Remove Member",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/api/workspaces/{{workspaceId}}/members/{{userId}}"
          }
        },
        {
          "name": "Leave Workspace",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/api/workspaces/{{workspaceId}}/members/me"
          }
        }
      ]
    },
    {
      "name": "Channels",
      "item": [
        {
          "name": "Create Channel (Public)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/api/workspaces/{{workspaceId}}/channels",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"general\",\n  \"isPrivate\": false\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Create Channel (Private)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/api/workspaces/{{workspaceId}}/channels",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"admin-only\",\n  \"isPrivate\": true\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "List Channels by Workspace",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/api/workspaces/{{workspaceId}}/channels"
          }
        },
        {
          "name": "Get Channel by Id",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/api/workspaces/{{workspaceId}}/channels/{{channelId}}"
          }
        },
        {
          "name": "Update Channel",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/api/workspaces/{{workspaceId}}/channels/{{channelId}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"general-updated\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Delete Channel",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/api/workspaces/{{workspaceId}}/channels/{{channelId}}"
          }
        }
      ]
    },
    {
      "name": "Messages",
      "item": [
        {
          "name": "Send Message (Text Only)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/api/channels/{{channelId}}/messages",
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "Content", "value": "Hola equipo, este es un mensaje de prueba!", "type": "text" }
              ]
            }
          }
        },
        {
          "name": "Send Message (Text + File)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/api/channels/{{channelId}}/messages",
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "Content", "value": "Aqui va el archivo adjunto", "type": "text" },
                { "key": "Attachments", "type": "file", "src": "" }
              ]
            }
          }
        },
        {
          "name": "Send Message (File Only)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/api/channels/{{channelId}}/messages",
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "Attachments", "type": "file", "src": "" }
              ]
            }
          }
        },
        {
          "name": "List Messages",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/channels/{{channelId}}/messages?pageNumber=1&pageSize=20",
              "host": ["{{baseUrl}}"],
              "path": ["api", "channels", "{{channelId}}", "messages"],
              "query": [
                { "key": "pageNumber", "value": "1" },
                { "key": "pageSize", "value": "20" }
              ]
            }
          }
        },
        {
          "name": "Update Message",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/api/channels/{{channelId}}/messages/{{messageId}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"content\": \"Este mensaje fue editado\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Delete Message",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/api/channels/{{channelId}}/messages/{{messageId}}"
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    },
    {
      "key": "refreshToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "workspaceId",
      "value": "",
      "type": "string"
    },
    {
      "key": "channelId",
      "value": "",
      "type": "string"
    },
    {
      "key": "messageId",
      "value": "",
      "type": "string"
    },
    {
      "key": "userId",
      "value": "",
      "type": "string"
    }
  ]
}
